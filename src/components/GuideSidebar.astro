---
import { getCollection } from 'astro:content';
import { GUIDE_CATEGORIES, type CategorySlug } from '../utils/categories';
import { groupByChapter } from '../utils/chapterGrouping';

interface Props {
  /** 只显示指定分类，不传则显示全部 */
  categories?: CategorySlug[];
  /** 链接前缀，如 '/cuda'，默认 '/guides' */
  urlPrefix?: string;
}

const { categories, urlPrefix = '/guides' } = Astro.props;

const guides = await getCollection('guides', ({ data }) => !data.draft);
const currentPath = decodeURIComponent(Astro.url.pathname);

const gradientMap: Record<string, string> = {
  'learning-path': '#3B82F6',
  'prerequisites': '#06B6D4',
  'cuda-optimization': '#F59E0B',
  'distributed-training': '#10B981',
  'inference-optimization': '#8B5CF6',
  'performance-analysis': '#F97316',
};

const categoriesToShow = categories
  ? Object.entries(GUIDE_CATEGORIES).filter(([slug]) => categories.includes(slug as CategorySlug))
  : Object.entries(GUIDE_CATEGORIES);

const getGuidePath = (guideId: string) => {
  const base = import.meta.env.BASE_URL;
  const path = `${urlPrefix}/${guideId}`;
  return base === '/' ? path : `${base.replace(/\/$/, '')}${path}`;
};

const isActivePath = (guideId: string) => {
  const guidePath = getGuidePath(guideId);
  const normalizedCurrent = currentPath.replace(/\/$/, '');
  const normalizedGuide = guidePath.replace(/\/$/, '');
  return normalizedCurrent === normalizedGuide;
};

const grouped = categoriesToShow
  .map(([slug, meta]) => {
    const items = guides
      .filter((g) => g.data.category === slug)
      .sort((a, b) => a.data.order - b.data.order);
    const chapterData = groupByChapter(items);
    return {
      slug: slug as CategorySlug,
      ...meta,
      color: gradientMap[slug] || '#3B82F6',
      items,
      chapterData,
    };
  })
  .filter((group) => group.items.length > 0);
---

<nav class="w-72 shrink-0 sticky top-24 h-[calc(100vh-8rem)] overflow-y-auto sidebar-scroll pr-2">
  <div class="space-y-6">
    {grouped.map((group) => {
      const { chapters, ungrouped } = group.chapterData;
      const hasChapters = chapters.length > 0;

      return (
        <div>
          {/* Category header */}
          <div class="flex items-center gap-2.5 px-3 mb-2">
            <div class="w-1.5 h-1.5 rounded-full shrink-0" style={`background: ${group.color};`} />
            <span class="text-xs font-semibold text-gray-900 dark:text-gray-100 tracking-wide truncate">
              {group.label}
            </span>
            <span class="text-[10px] text-gray-400 dark:text-gray-500 font-medium ml-auto tabular-nums">
              {group.items.length}
            </span>
          </div>

          {/* Links */}
          <ul class="relative ml-[11px] border-l border-gray-200 dark:border-white/[0.06] space-y-px">
            {/* Ungrouped items first */}
            {ungrouped.map((item) => {
              const href = getGuidePath(item.id);
              const isActive = isActivePath(item.id);
              return (
                <li class="relative">
                  {isActive && (
                    <div class="absolute left-0 top-1.5 bottom-1.5 w-[2px] -translate-x-[1px] rounded-full" style={`background: ${group.color};`} />
                  )}
                  <a
                    href={href}
                    data-active={isActive ? 'true' : undefined}
                    class:list={[
                      'block ml-4 px-3 py-1.5 rounded-lg text-[13px] leading-snug transition-all duration-200 cursor-pointer',
                      isActive
                        ? 'text-gray-900 dark:text-white font-medium bg-gray-100 dark:bg-white/[0.06]'
                        : 'text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-white/[0.04]',
                    ]}
                  >
                    {item.data.title}
                  </a>
                </li>
              );
            })}

            {/* Chapter groups */}
            {hasChapters && chapters.map((ch) => {
              const chapterHref = getGuidePath(ch.chapter.id);
              const isChapterActive = isActivePath(ch.chapter.id);
              const hasChildren = ch.children.length > 0;
              const isChildActive = ch.children.some((c) => isActivePath(c.id));
              const isExpanded = isChapterActive || isChildActive;

              return (
                <li class="relative chapter-group" data-expanded={isExpanded ? 'true' : 'false'}>
                  {/* Chapter active indicator */}
                  {isChapterActive && (
                    <div class="absolute left-0 top-1.5 bottom-auto h-8 w-[2px] -translate-x-[1px] rounded-full" style={`background: ${group.color};`} />
                  )}

                  {/* Chapter header row */}
                  <div class="flex items-center ml-4">
                    <a
                      href={chapterHref}
                      data-active={isChapterActive ? 'true' : undefined}
                      class:list={[
                        'flex-1 px-3 py-1.5 rounded-lg text-[13px] leading-snug transition-all duration-200 cursor-pointer font-medium',
                        isChapterActive
                          ? 'text-gray-900 dark:text-white bg-gray-100 dark:bg-white/[0.06]'
                          : 'text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-white/[0.04]',
                      ]}
                    >
                      {ch.chapter.data.title}
                    </a>
                    {hasChildren && (
                      <button
                        class="chapter-toggle w-6 h-6 flex items-center justify-center text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors shrink-0"
                        aria-label="展开/折叠"
                      >
                        <svg class:list={['w-3.5 h-3.5 transition-transform duration-200', isExpanded && 'rotate-90']} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                      </button>
                    )}
                  </div>

                  {/* Child articles */}
                  {hasChildren && (
                    <ul class:list={['chapter-children ml-4 pl-3 border-l border-gray-100 dark:border-white/[0.04] space-y-px mt-px', !isExpanded && 'hidden']}>
                      {ch.children.map((child) => {
                        const childHref = getGuidePath(child.id);
                        const isChildItemActive = isActivePath(child.id);
                        return (
                          <li class="relative">
                            {isChildItemActive && (
                              <div class="absolute left-0 top-1.5 bottom-1.5 w-[2px] -translate-x-[1px] rounded-full" style={`background: ${group.color};`} />
                            )}
                            <a
                              href={childHref}
                              data-active={isChildItemActive ? 'true' : undefined}
                              class:list={[
                                'block ml-3 px-3 py-1.5 rounded-lg text-[12px] leading-snug transition-all duration-200 cursor-pointer',
                                isChildItemActive
                                  ? 'text-gray-900 dark:text-white font-medium bg-gray-100 dark:bg-white/[0.06]'
                                  : 'text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-white/[0.04]',
                              ]}
                            >
                              {child.data.title}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      );
    })}
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Scroll active link into view
    const sidebar = document.querySelector('.sidebar-scroll') as HTMLElement | null;
    const activeLink = sidebar?.querySelector('a[data-active="true"]') as HTMLElement | null;
    if (sidebar && activeLink) {
      const sidebarRect = sidebar.getBoundingClientRect();
      const linkRect = activeLink.getBoundingClientRect();
      const offset = linkRect.top - sidebarRect.top - sidebarRect.height / 2 + linkRect.height / 2;
      sidebar.scrollTop += offset;
    }

    // Chapter toggle buttons
    document.querySelectorAll('.chapter-toggle').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const group = btn.closest('.chapter-group') as HTMLElement | null;
        if (!group) return;
        const children = group.querySelector('.chapter-children') as HTMLElement | null;
        const svg = btn.querySelector('svg');
        if (!children) return;

        const isHidden = children.classList.contains('hidden');
        if (isHidden) {
          children.classList.remove('hidden');
          svg?.classList.add('rotate-90');
          group.dataset.expanded = 'true';
        } else {
          children.classList.add('hidden');
          svg?.classList.remove('rotate-90');
          group.dataset.expanded = 'false';
        }
      });
    });
  });
</script>
