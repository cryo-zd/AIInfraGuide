---
import { getCollection } from 'astro:content';
import GuideSidebar from './GuideSidebar.astro';
import { GUIDE_CATEGORIES, type CategorySlug } from '../utils/categories';
import { groupByChapter } from '../utils/chapterGrouping';
import { MODULE_METADATA } from '../utils/moduleMetadata';

interface Props {
  category: CategorySlug;
  urlPrefix: string;
}

const { category, urlPrefix } = Astro.props;

const meta = MODULE_METADATA[category];
const categoryMeta = GUIDE_CATEGORIES[category];

const guides = await getCollection('guides', ({ data }) => !data.draft && data.category === category);
const sorted = guides.sort((a, b) => a.data.order - b.data.order);
const { chapters, ungrouped } = groupByChapter(sorted);

const totalArticles = sorted.length;

const getPath = (path: string) => {
  const base = import.meta.env.BASE_URL;
  return base === '/' ? path : `${base.replace(/\/$/, '')}${path}`;
};

const firstGuide = sorted[0];
const startHref = firstGuide ? getPath(`${urlPrefix}/${firstGuide.id}`) : '#';
---

<div class="max-w-[1500px] mx-auto px-6 py-12 flex gap-10">
  <!-- Left Sidebar -->
  <aside class="hidden lg:block">
    <GuideSidebar categories={[category]} urlPrefix={urlPrefix} />
  </aside>

  <!-- Main Content -->
  <div class="flex-1 min-w-0">
    {/* Hero Section */}
    <div class="mb-12 pb-8 border-b border-gray-200 dark:border-white/[0.06]">
      <div class="flex items-center gap-3 mb-5">
        <span
          class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-md"
          style={`background: ${meta?.color || '#3B82F6'}15; color: ${meta?.color || '#3B82F6'};`}
        >
          {categoryMeta.icon} {categoryMeta.label}
        </span>
        <span class="text-xs text-gray-400 dark:text-gray-500 font-medium tabular-nums">
          {totalArticles} 篇文章 · {chapters.length} 个章节
        </span>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4 leading-tight">
        {meta?.title || categoryMeta.label}
      </h1>

      <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed mb-8">
        {meta?.description || `${categoryMeta.label}相关技术文档`}
      </p>

      {firstGuide && (
        <a
          href={startHref}
          class="group inline-flex items-center gap-2 px-6 py-3 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-xl font-semibold hover:bg-gray-800 dark:hover:bg-gray-100 transition-all duration-300 shadow-lg shadow-gray-900/10 dark:shadow-white/10 cursor-pointer text-sm"
        >
          开始学习
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      )}
    </div>

    {/* Chapter Directory */}
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">章节目录</h2>

      {/* Ungrouped articles */}
      {ungrouped.length > 0 && (
        <div class="mb-6 rounded-xl border border-gray-200 dark:border-white/[0.06] overflow-hidden">
          <ul class="divide-y divide-gray-100 dark:divide-white/[0.04]">
            {ungrouped.map((item) => (
              <li>
                <a
                  href={getPath(`${urlPrefix}/${item.id}`)}
                  class="flex items-center gap-3 px-6 py-3.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-white/[0.04] hover:text-gray-900 dark:hover:text-white transition-colors cursor-pointer"
                >
                  <svg class="w-4 h-4 text-gray-400 dark:text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                  </svg>
                  {item.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Chapter cards */}
      <div class="space-y-5">
        {chapters.map((ch, i) => {
          const chapterHref = getPath(`${urlPrefix}/${ch.chapter.id}`);
          const color = meta?.color || '#3B82F6';
          return (
            <div class="rounded-xl border border-gray-200 dark:border-white/[0.06] overflow-hidden">
              {/* Chapter header */}
              <div class="px-6 py-4 flex items-center gap-3" style={`background: ${color}10;`}>
                <span
                  class="w-7 h-7 rounded-lg flex items-center justify-center text-xs font-bold shrink-0"
                  style={`background: ${color}20; color: ${color};`}
                >
                  {i + 1}
                </span>
                <a
                  href={chapterHref}
                  class="font-semibold text-gray-900 dark:text-white text-[15px] hover:text-[#007aff] dark:hover:text-[#0a84ff] transition-colors cursor-pointer"
                >
                  {ch.chapter.data.title}
                </a>
                {ch.children.length > 0 && (
                  <span class="ml-auto text-xs text-gray-400 dark:text-gray-500 font-medium tabular-nums">
                    {ch.children.length} 篇
                  </span>
                )}
              </div>

              {/* Chapter description */}
              {ch.chapter.data.description && (
                <div class="px-6 py-3 text-sm text-gray-500 dark:text-gray-400 border-b border-gray-100 dark:border-white/[0.04]">
                  {ch.chapter.data.description}
                </div>
              )}

              {/* Child articles */}
              {ch.children.length > 0 && (
                <ul class="divide-y divide-gray-100 dark:divide-white/[0.04]">
                  {ch.children.map((child) => (
                    <li>
                      <a
                        href={getPath(`${urlPrefix}/${child.id}`)}
                        class="flex items-center gap-3 px-6 py-3 text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-white/[0.04] hover:text-gray-900 dark:hover:text-white transition-colors cursor-pointer"
                      >
                        <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                        </svg>
                        {child.data.title}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          );
        })}
      </div>
    </div>

    {/* Learning Tips */}
    {meta?.tips && meta.tips.length > 0 && (
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">学习建议</h2>
        <div class="rounded-xl border border-gray-200 dark:border-white/[0.06] p-6 bg-white dark:bg-white/[0.02]">
          {meta.prerequisites && (
            <div class="mb-5 pb-5 border-b border-gray-100 dark:border-white/[0.06]">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-2 flex items-center gap-2">
                <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                </svg>
                前置要求
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">{meta.prerequisites}</p>
            </div>
          )}
          <ul class="space-y-3">
            {meta.tips.map((tip) => (
              <li class="flex items-start gap-3 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-5 h-5 shrink-0 mt-0.5" style={`color: ${meta.color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                {tip}
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}
  </div>

  <!-- Right Sidebar (empty, matches article page layout) -->
  <aside class="hidden xl:block w-64 shrink-0" />
</div>
