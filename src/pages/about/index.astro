---
import Layout from '../../layouts/Layout.astro';

const getPath = (path: string) => {
  const base = import.meta.env.BASE_URL;
  return base === '/' ? path : `${base.replace(/\/$/, '')}${path}`;
};

const pages = [
  {
    title: '欢迎来到 AIInfraGuide',
    description: '了解项目愿景、内容体系和参与方式',
    href: getPath('/about/welcome'),
    icon: '🚀',
  },
  {
    title: '草帽路飞介绍',
    description: '关于作者、技术背景和联系方式',
    href: getPath('/about/author'),
    icon: '👋',
  },
  {
    title: '教程更新计划',
    description: '四大模块的章节规划与更新节奏',
    href: getPath('/about/roadmap'),
    icon: '📅',
  },
];
---

<Layout title="关于 - AIInfraGuide" description="关于 AIInfraGuide 项目和作者">
  <div class="py-24 max-w-3xl mx-auto px-6">
    <div class="mb-12 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 dark:text-white">关于</h1>
      <p class="text-lg text-gray-500 dark:text-gray-400">了解 AIInfraGuide 和背后的作者</p>
    </div>

    <div class="grid gap-4">
      {pages.map((page) => (
        <a
          href={page.href}
          class="group flex items-start gap-5 p-6 rounded-xl border border-gray-200 dark:border-white/[0.06] hover:border-gray-300 dark:hover:border-white/[0.12] hover:shadow-lg transition-all duration-300 cursor-pointer"
        >
          <span class="text-3xl shrink-0 mt-0.5">{page.icon}</span>
          <div>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-[#007aff] dark:group-hover:text-[#0a84ff] transition-colors duration-200">
              {page.title}
            </h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{page.description}</p>
          </div>
          <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 group-hover:text-[#007aff] dark:group-hover:text-[#0a84ff] ml-auto mt-1.5 shrink-0 transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</Layout>
