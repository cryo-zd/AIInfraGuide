---
import Layout from '../../layouts/Layout.astro';

const getPath = (path: string) => {
  const base = import.meta.env.BASE_URL;
  return base === '/' ? path : `${base.replace(/\/$/, '')}${path}`;
};
---

<Layout title="草帽路飞介绍 - AIInfraGuide" description="关于 AIInfraGuide 作者草帽路飞">
  <article class="py-24 max-w-3xl mx-auto px-6">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm text-gray-400 dark:text-gray-500">
      <a href={getPath('/about')} class="hover:text-[#007aff] dark:hover:text-[#0a84ff] transition-colors">关于</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600 dark:text-gray-300">草帽路飞</span>
    </nav>

    <div class="mb-12 text-center">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 leading-tight text-gray-900 dark:text-white">
        草帽路飞介绍
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400">AI Infra 开发者 / HPC 背景 / 算子优化</p>
    </div>

    <div
      class="prose prose-gray dark:prose-invert prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-white
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:border-b prose-h2:border-gray-200 dark:prose-h2:border-white/10 prose-h2:pb-2
        prose-h3:text-xl
        prose-a:text-[#007aff] dark:prose-a:text-[#0a84ff] prose-a:no-underline hover:prose-a:underline
        prose-hr:border-gray-200 dark:prose-hr:border-white/10"
    >
      <h2>关于我</h2>
      <p>你好！我是 <strong>草帽路飞</strong>，一名专注于 AI Infra 方向的技术开发者，热衷于 GPU 编程、深度学习系统优化以及大模型训练与推理。</p>
      <p>本人硕士是传统高性能计算 HPC 方向，主要做 CPU 和 GPU 的数值模式的优化，比较擅长算子优化。硕士期间 3 段高性能计算实习经历，校招进入某大厂做 AI Infra 开发。自己以前对大模型相关知识并没有系统性学过，所以在日常工作中经常遇到很多大模型训练和推理层的新概念，都是现学现卖。虽然工作的活都顺利干完了，但是知识点学的比较零散，没有一个全局的知识视角。</p>
      <p>我觉得还是很有必要系统性地学习一下 AI Infra 相关知识，争取成为一个 AI Infra 全栈工程师。后续我将持续更新分享自己的学习笔记和相关教程。有对 AI Infra 感兴趣以及想学习的朋友，可以关注我，和我一起进步成长～</p>

      <h2>联系方式</h2>
      <p>欢迎通过以下方式与我交流：</p>
      <ul>
        <li>公众号: <a href="https://mp.weixin.qq.com/s/oxUBDTd-b1aZnh0jGR5tqw" target="_blank" rel="noopener noreferrer">《AI炼金炉》</a>(有vx)</li>
        <li>知乎: <a href="https://zhihu.com/people/zi-you-zi-zai-de-zhan-sheng" target="_blank" rel="noopener noreferrer">草帽路飞</a></li>
      </ul>
    </div>

    <!-- Navigation -->
    <div class="mt-16 pt-8 border-t border-gray-200 dark:border-white/[0.06] flex justify-between">
      <a
        href={getPath('/about/welcome')}
        class="group flex items-center gap-2 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-[#007aff] dark:hover:text-[#0a84ff] transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        欢迎来到 AIInfraGuide
      </a>
      <a
        href={getPath('/about/roadmap')}
        class="group flex items-center gap-2 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-[#007aff] dark:hover:text-[#0a84ff] transition-colors"
      >
        教程更新计划
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </article>
</Layout>
