---
import Layout from '../../layouts/Layout.astro';

const getPath = (path: string) => {
  const base = import.meta.env.BASE_URL;
  return base === '/' ? path : `${base.replace(/\/$/, '')}${path}`;
};

const modules = [
  {
    name: '模块一：前置知识',
    color: '#06B6D4',
    chapters: [
      '第1章 编程语言基础',
      '第2章 数学基础',
      '第3章 Transformer 架构详解',
      '第4章 PyTorch 框架',
      '第5章 GPU 硬件概论',
      '第6章 集合通信基础',
    ],
  },
  {
    name: '模块二：CUDA 编程与算子优化',
    color: '#F59E0B',
    chapters: [
      '第1章 CUDA 编程入门',
      '第2章 CUDA 性能优化基础',
      '第3章 经典算子实现 - Reduce',
      '第4章 经典算子实现 - GEMM',
      '第5章 经典算子实现 - Softmax 与算子融合',
      '第6章 Attention 算子',
      '第7章 AI 编译器',
      '第8章 性能分析工具链',
    ],
  },
  {
    name: '模块三：分布式训练',
    color: '#10B981',
    chapters: [
      '第1章 分布式训练总论',
      '第2章 数据并行',
      '第3章 ZeRO 系列',
      '第4章 张量并行与序列并行',
      '第5章 流水线并行',
      '第6章 3D 并行与混合训练策略',
      '第7章 训练框架实战',
    ],
  },
  {
    name: '模块四：推理优化',
    color: '#8B5CF6',
    chapters: [
      '第1章 LLM 推理基础',
      '第2章 推理引擎核心技术',
      '第3章 主流推理框架',
      '第4章 量化',
      '第5章 Speculative Decoding',
      '第6章 PD 解耦架构',
      '第7章 性能分析与 Benchmark',
      '第8章 推理优化选型与端到端实战',
    ],
  },
];
---

<Layout title="教程更新计划 - AIInfraGuide" description="AIInfraGuide 本站教程的更新计划与进度安排">
  <article class="py-24 max-w-3xl mx-auto px-6">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm text-gray-400 dark:text-gray-500">
      <a href={getPath('/about')} class="hover:text-[#007aff] dark:hover:text-[#0a84ff] transition-colors">关于</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600 dark:text-gray-300">教程更新计划</span>
    </nav>

    <div class="mb-12 text-center">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 leading-tight text-gray-900 dark:text-white">
        本站教程更新计划
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400">四大模块、29 个章节的系统化更新路线</p>
    </div>

    <div
      class="prose prose-gray dark:prose-invert prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-white
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:border-b prose-h2:border-gray-200 dark:prose-h2:border-white/10 prose-h2:pb-2
        prose-h3:text-xl
        prose-a:text-[#007aff] dark:prose-a:text-[#0a84ff] prose-a:no-underline hover:prose-a:underline
        prose-hr:border-gray-200 dark:prose-hr:border-white/10"
    >
      <!-- 写在前面 -->
      <div class="not-prose mb-10 p-6 rounded-xl bg-blue-50/80 dark:bg-blue-900/10 border border-blue-100 dark:border-blue-800/20">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#007aff] dark:text-[#0a84ff]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
          </svg>
          写在前面
        </h2>
        <p class="text-[15px] text-gray-600 dark:text-gray-300 leading-relaxed mb-3">
          感谢大家对 AIInfraGuide 的关注和支持！作者白天需要上班，只能利用<strong>晚上和周末</strong>的业余时间来编写和更新教程内容。因此更新节奏可能不会特别快，但我会尽量保证每篇文章的质量和深度。
        </p>
        <p class="text-[15px] text-gray-600 dark:text-gray-300 leading-relaxed mb-3">
          如果你觉得这个项目对你有帮助，希望能给个 <strong><a href="https://github.com/caomaolufei/AIInfraGuide" target="_blank" rel="noopener noreferrer" class="text-[#007aff] dark:text-[#0a84ff] font-medium hover:underline">Star</a> </strong> 鼓励一下，也欢迎分享给身边对 AI Infra 感兴趣的朋友。你们的支持是我持续更新的最大动力！
        </p>
        <p class="text-[15px] text-gray-600 dark:text-gray-300 leading-relaxed">
          有任何建议或想看的内容，欢迎通过 <strong> GitHub Issue</strong> 或者 <strong> 公众号留言</strong> 告诉我。
        </p>
      </div>

      <!-- 最新动态 -->
      <div class="not-prose mb-10 p-6 rounded-xl bg-emerald-50/80 dark:bg-emerald-900/10 border border-emerald-100 dark:border-emerald-800/20">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6V7.5Z" />
          </svg>
          获取最新更新
        </h2>
        <p class="text-[15px] text-gray-600 dark:text-gray-300 leading-relaxed">
          作者新产出的文章都会第一时间在 <a href="https://zhihu.com/people/zi-you-zi-zai-de-zhan-sheng" target="_blank" rel="noopener noreferrer" class="text-emerald-700 dark:text-emerald-400 font-semibold hover:underline">知乎</a> 和 <a href="https://mp.weixin.qq.com/s/oxUBDTd-b1aZnh0jGR5tqw" target="_blank" rel="noopener noreferrer" class="text-emerald-700 dark:text-emerald-400 font-semibold hover:underline">公众号《AI炼金炉》</a> 发布，之后才会同步更新到 GitHub 和本站。想第一时间了解最新内容，推荐关注知乎或公众号。
        </p>
      </div>

      <h2>更新计划总览</h2>
      <p>本站教程共分为 <strong>4 个模块</strong>，覆盖从前置基础到推理优化的完整 AI Infra 技术栈。以下是各模块的章节规划和更新安排：</p>
    </div>

    <!-- Module Cards -->
    <div class="mt-8 space-y-6">
      {modules.map((mod, i) => (
        <div class="rounded-xl border border-gray-200 dark:border-white/[0.06] overflow-hidden">
          <div class="px-6 py-4 flex items-center gap-3" style={`background: ${mod.color}10;`}>
            <div class="w-2 h-2 rounded-full shrink-0" style={`background: ${mod.color};`} />
            <h3 class="font-semibold text-gray-900 dark:text-white text-[15px]">{mod.name}</h3>
            <span class="ml-auto text-xs text-gray-400 dark:text-gray-500 font-medium tabular-nums">{mod.chapters.length} 章</span>
          </div>
          <ul class="divide-y divide-gray-100 dark:divide-white/[0.04]">
            {mod.chapters.map((ch, j) => (
              <li class="px-6 py-3 flex items-center gap-3 text-sm">
                <span class="w-5 h-5 rounded-md flex items-center justify-center text-[11px] font-semibold shrink-0" style={`background: ${mod.color}15; color: ${mod.color};`}>
                  {j + 1}
                </span>
                <span class="text-gray-700 dark:text-gray-300">{ch}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- 更新节奏 -->
    <div class="mt-12 prose prose-gray dark:prose-invert prose-lg max-w-none
      prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-white
      prose-h2:text-2xl prose-h2:mt-12 prose-h2:border-b prose-h2:border-gray-200 dark:prose-h2:border-white/10 prose-h2:pb-2">
      <h2>更新节奏</h2>
      <ul>
        <li><strong>更新频率</strong>：预计每周 1-2 篇，视内容深度和工作强度调整</li>
        <li><strong>更新顺序</strong>：按模块顺序推进，优先完成前置知识和 CUDA 编程模块</li>
        <li><strong>内容质量</strong>：每篇文章遵循「先白话后术语」的原则，配合代码示例和图解</li>
        <li><strong>反馈驱动</strong>：如果某个章节呼声较高，会考虑优先更新</li>
      </ul>
    </div>

    <!-- Navigation -->
    <div class="mt-16 pt-8 border-t border-gray-200 dark:border-white/[0.06] flex justify-start">
      <a
        href={getPath('/about/author')}
        class="group flex items-center gap-2 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-[#007aff] dark:hover:text-[#0a84ff] transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        草帽路飞介绍
      </a>
    </div>
  </article>
</Layout>
