---
import Layout from '../layouts/Layout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { getCollection } from 'astro:content';
import { GUIDE_CATEGORIES, type CategorySlug } from '../utils/categories';

const guides = await getCollection('guides', ({ data }) => !data.draft);
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const categoryCounts = Object.entries(GUIDE_CATEGORIES).map(([slug, meta]) => ({
  slug: slug as CategorySlug,
  ...meta,
  count: guides.filter((g) => g.data.category === slug).length,
  firstGuide: guides
    .filter((g) => g.data.category === slug)
    .sort((a, b) => a.data.order - b.data.order)[0],
}));

const categoryDescriptions: Record<string, string> = {
  'learning-path': '系统化的 AIInfra 学习路径与知识图谱',
  'prerequisites': 'GPU 架构、计算机体系结构等核心前置知识',
  'cuda-optimization': 'CUDA 编程模型、算子开发与性能优化',
  'distributed-training': '数据并行、模型并行与大规模分布式训练',
  'inference-optimization': '模型压缩、量化加速与推理引擎优化',
  'performance-analysis': '性能瓶颈定位、Profiling 工具与调优策略',
};

const categoryUrlPrefix: Record<string, string> = {
  'learning-path': '/guides',
  'prerequisites': '/prerequisites',
  'cuda-optimization': '/cuda',
  'distributed-training': '/distributed',
  'inference-optimization': '/inference',
  'performance-analysis': '/guides',
};

const getPath = (path: string) => {
  const base = import.meta.env.BASE_URL;
  return base === '/' ? path : `${base.replace(/\/$/, '')}${path}`;
};

// 获取每个模块的第一篇文章URL，与导航栏逻辑一致
const getFirstGuideUrl = (category: string, urlPrefix: string) => {
  const first = guides
    .filter((g) => g.data.category === category)
    .sort((a, b) => a.data.order - b.data.order)[0];
  return first ? getPath(`${urlPrefix}/${first.id}`) : getPath('/');
};
---

<Layout>
  <!-- Hero Section -->
  <section class="relative pt-28 pb-24 overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0 pointer-events-none">
      <!-- Grid pattern -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,.03)_1px,transparent_1px)] dark:bg-[linear-gradient(rgba(255,255,255,.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
      <!-- Gradient orbs -->
      <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-blue-500/[0.08] dark:bg-blue-500/[0.12] rounded-full blur-[120px]"></div>
      <div class="absolute top-20 right-1/4 w-[400px] h-[400px] bg-violet-500/[0.06] dark:bg-violet-500/[0.10] rounded-full blur-[120px]"></div>
      <!-- Fade out at bottom -->
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white dark:from-black to-transparent"></div>
    </div>

    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 rounded-full border border-gray-200 dark:border-white/10 bg-white/80 dark:bg-white/5 backdrop-blur-sm text-sm text-gray-600 dark:text-gray-400">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        开源 AI Infra 学习指南
      </div>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
        <span class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 dark:from-white dark:via-gray-200 dark:to-white bg-clip-text text-transparent">
          AI Infra
        </span>
        <span class="bg-gradient-to-r from-[#007aff] via-[#5856D6] to-[#AF52DE] bg-clip-text text-transparent">
          Guide
        </span>
      </h1>

      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-3 font-medium">
        从零开始深入理解 AI Infra 的全栈核心技术（持续更新中）
      </p>
      <p class="text-sm text-gray-500 dark:text-gray-500 mb-10 max-w-xl mx-auto leading-relaxed">
        从底层的 CUDA 编程到模型的分布式训练和推理优化，构建完整的 AI Infra 知识体系
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        {categoryCounts.find((c) => c.firstGuide) && (
          <a
            href={getFirstGuideUrl(categoryCounts.find((c) => c.firstGuide)!.slug, categoryUrlPrefix[categoryCounts.find((c) => c.firstGuide)!.slug] || '/guides')}
            class="group inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-xl font-semibold hover:bg-gray-800 dark:hover:bg-gray-100 transition-all duration-300 shadow-lg shadow-gray-900/10 dark:shadow-white/10 cursor-pointer"
          >
            开始学习
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        )}
        <a
          href="https://github.com/caomaolufei/AIInfraGuide"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-white dark:bg-white/5 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-white/10 rounded-xl font-semibold hover:border-gray-300 dark:hover:border-white/20 hover:bg-gray-50 dark:hover:bg-white/10 transition-all duration-300 cursor-pointer"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Guide Categories -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-3">知识库</h2>
        <p class="text-gray-500 dark:text-gray-400 max-w-md mx-auto">系统化的 AI Infra 全栈核心技术学习文档</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {categoryCounts.map((cat) => (
          <CategoryCard
            icon={cat.icon}
            title={cat.label}
            description={categoryDescriptions[cat.slug] || `${cat.label}相关的技术文档`}
            href={getPath(categoryUrlPrefix[cat.slug] || '/guides')}
            count={cat.count}
            slug={cat.slug}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  {posts.length > 0 && (
    <section class="py-20 border-t border-gray-100 dark:border-white/[0.04]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-14">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-3">博客文章</h2>
          <p class="text-gray-500 dark:text-gray-400 max-w-md mx-auto">
            最近发布的博客文章 ·
            <a
              href={getPath('/blog')}
              class="inline-flex items-center gap-1 text-gray-500 dark:text-gray-400 hover:text-[#007aff] dark:hover:text-[#0a84ff] transition-colors duration-200 cursor-pointer"
            >
              查看全部
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {posts.map((post) => (
            <a
              href={getPath(`/blog/${post.id}`)}
              class="group block p-6 bg-white dark:bg-white/[0.03] border border-gray-200 dark:border-white/[0.06] rounded-2xl hover:border-gray-300 dark:hover:border-white/[0.12] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] cursor-pointer"
            >
              <div class="flex gap-2 mb-3 flex-wrap">
                {post.data.tags.map((tag) => (
                  <span class="px-2.5 py-0.5 bg-gray-100 dark:bg-white/[0.06] text-gray-600 dark:text-gray-400 text-xs rounded-md font-medium">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-[#007aff] dark:group-hover:text-[#0a84ff] transition-colors duration-200 mb-2 flex items-start gap-2">
                <svg class="w-5 h-5 shrink-0 mt-0.5 text-[#007aff] dark:text-[#0a84ff] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                </svg>
                <span>{post.data.title}</span>
              </h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2 mb-4 leading-relaxed">
                {post.data.description}
              </p>
              <time class="text-xs text-gray-400 dark:text-gray-500 font-medium" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
